<?xml version="1.0" encoding="UTF-8" ?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Accuracy_Pct__c</fullName>
    <description
    >Times_Correct / Times_Seen * 100. Used for &quot;weakest topics&quot; lists and study-plan generation.</description>
    <externalId>false</externalId>
    <formula
    >IF(Times_Seen__c = 0, 0, (Times_Correct__c / Times_Seen__c) * 100)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Accuracy %</label>
    <precision>18</precision>
    <scale>1</scale>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>