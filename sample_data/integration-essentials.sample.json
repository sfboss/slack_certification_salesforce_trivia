            "domain": "Limits",
            "difficulty": "Intermediate",
            "questionType": "Single Select",
            "question": "What is the synchronous callout time limit for an Apex transaction?",
            "choices": [
                {
                    "label": "A",
                    "text": "10 seconds",
                    "isCorrect": false,
                    "explanation": "Below the actual limit."
                },
                {
                    "label": "B",
                    "text": "60 seconds total / 120 seconds for queueable",
                    "isCorrect": false,
                    "explanation": "These numbers are not the documented values."
                },
                {
                    "label": "C",
                    "text": "120 seconds total per transaction (synchronous)",
                    "isCorrect": true,
                    "explanation": "Cumulative callout time limit is 120 seconds in synchronous Apex."
                },
                {
                    "label": "D",
                    "text": "Unlimited",
                    "isCorrect": false,
                    "explanation": "Callouts have time limits."
                }
            ],
            "explanation": "Synchronous Apex allows up to 120 seconds total callout time per transaction.",
            "citations": [
                {
                    "title": "Apex Governor Limits — Callouts",
                    "url": "https://developer.salesforce.com/docs/atlas.en-us.apexcode.meta/apexcode/apex_gov_limits.htm",
