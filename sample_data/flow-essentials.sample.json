            "externalId": "FLOW-Q5",
            "domain": "Bulkification",
            "difficulty": "Advanced",
            "questionType": "Single Select",
            "question": "Which is the BEST practice for performing DML on multiple records inside a flow?",
            "choices": [
                {
                    "label": "A",
                    "text": "Loop the records and call Update Records inside the loop",
                    "isCorrect": false,
                    "explanation": "DML inside loops violates bulkification limits."
                },
                {
                    "label": "B",
                    "text": "Build a collection inside the loop, then Update Records once after the loop",
                    "isCorrect": true,
                    "explanation": "Collect into a variable and DML once after the loop."
                },
                {
                    "label": "C",
                    "text": "Call a Queueable Apex action for each record",
                    "isCorrect": false,
                    "explanation": "Per-record async invocations are inefficient."
                },
                {
                    "label": "D",
                    "text": "Use Scheduled Paths for each record separately",
                    "isCorrect": false,
                    "explanation": "Schedule per-record is unnecessary overhead."
                }
            ],
            "explanation": "Build a collection variable in the loop and run one Update Records after.",
            "citations": [
                {
                    "title": "Flow Best Practices",
                    "url": "https://help.salesforce.com/s/articleView?id=sf.flow_best_practices.htm",
                    "sourceType": "Salesforce Help",
