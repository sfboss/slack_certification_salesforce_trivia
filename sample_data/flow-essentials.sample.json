            "domain": "Flow Types",
            "difficulty": "Beginner",
            "questionType": "Single Select",
            "question": "Which Flow type runs without user interaction and is triggered by a record change?",
            "choices": [
                {
                    "label": "A",
                    "text": "Screen Flow",
                    "isCorrect": false,
                    "explanation": "Screen Flows require user interaction."
                },
                {
                    "label": "B",
                    "text": "Record-Triggered Flow",
                    "isCorrect": true,
                    "explanation": "Record-Triggered Flows fire on insert/update/delete."
                },
                {
                    "label": "C",
                    "text": "Autolaunched Flow (No Trigger)",
                    "isCorrect": false,
                    "explanation": "These run when called, not on record changes."
                },
                {
                    "label": "D",
                    "text": "Platform Event–Triggered Flow",
                    "isCorrect": false,
                    "explanation": "These fire on platform events, not record changes."
                }
            ],
            "explanation": "Record-Triggered Flows respond to DML on a specific object.",
            "citations": [
                {
                    "title": "Record-Triggered Flow",
                    "url": "https://help.salesforce.com/s/articleView?id=sf.flow_concepts_trigger_record.htm",
                    "sourceType": "Salesforce Help",
                    "relevanceNote": "Defines the trigger type."
                }
            ]
        },
        {
            "externalId": "FLOW-Q2",
            "domain": "Performance",
            "difficulty": "Intermediate",
            "questionType": "Single Select",
            "question": "Where should you place same-record field updates for the best performance in a Record-Triggered Flow?",
            "choices": [
                {
                    "label": "A",
                    "text": "After-save with Update Records",
                    "isCorrect": false,
                    "explanation": "After-save causes a second DML; not as efficient."
                },
                {
                    "label": "B",
                    "text": "Before-save Fast Field Update",
                    "isCorrect": true,
                    "explanation": "Before-save updates occur in the same DML, no recursion."
                },
                {
                    "label": "C",
                    "text": "Scheduled Path 0 minutes after",
                    "isCorrect": false,
                    "explanation": "Scheduled paths run asynchronously."
                },
                {
                    "label": "D",
                    "text": "Subflow called from a Process Builder",
                    "isCorrect": false,
                    "explanation": "Process Builder is retired; not a performance choice."
                }
            ],
            "explanation": "Before-save flows handle same-record updates in the same DML operation.",
            "citations": [
                {
                    "title": "Before-Save vs After-Save",
                    "url": "https://help.salesforce.com/s/articleView?id=sf.flow_concepts_trigger_before_save.htm",
                    "sourceType": "Salesforce Help",
                    "relevanceNote": "Performance comparison."
                }
            ]
