            "externalId": "CRT101-Q3",
            "domain": "Data Model",
            "difficulty": "Intermediate",
            "questionType": "Single Select",
            "question": "Which feature lets you store a many-to-many relationship between two custom objects?",
            "choices": [
                {
                    "label": "A",
                    "text": "A single master-detail field",
                    "isCorrect": false,
                    "explanation": "One M-D defines one parent only."
                },
                {
                    "label": "B",
                    "text": "Two master-detail fields on a junction object",
                    "isCorrect": true,
                    "explanation": "A junction object with two master-detail fields models many-to-many."
                },
                {
                    "label": "C",
                    "text": "A hierarchical relationship",
                    "isCorrect": false,
                    "explanation": "Hierarchical only applies to User."
                },
                {
                    "label": "D",
                    "text": "An external lookup",
                    "isCorrect": false,
                    "explanation": "External lookups target external objects."
                }
            ],
            "explanation": "Junction objects with two master-detail fields are the canonical M:M pattern.",
            "citations": [
                {
                    "title": "Many-to-Many Relationships",
                    "url": "https://help.salesforce.com/s/articleView?id=sf.relationships_manytomany.htm",
                    "sourceType": "Salesforce Help",
                    "relevanceNote": "Defines junction objects."
                }
